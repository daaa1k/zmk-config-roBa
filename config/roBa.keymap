#include <input/processors.dtsi>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

#define MOUSE 3

// マウスキーを押したらタイムアウトを10秒間延長する
// ※ 3 は AutoMouseLayer

&mkp_input_listener { input-processors = <&zip_temp_layer 3 10000>; };

&mt {
    flavor = "balanced";
    quick-tap-ms = <0>;
};

&trackball {
    // マウス層は zip_temp_layer のみ（automouse-layer は require-prior-idle と併用不可）
    scroll-layers = <4>;

    // arrows {
    //     layers = <3>;
    //     bindings =
    //         <&kp RIGHT_ARROW>,
    //         <&kp LEFT_ARROW>,
    //         <&kp UP_ARROW>,
    //         <&kp DOWN_ARROW>;
    //     tick = <10>;
    //     wait-ms = <5>;
    //     tap-ms = <5>;
    // };
};

/ {
    combos { compatible = "zmk,combos"; };

    macros {
        to_layer_0: to_layer_0 {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            bindings = <&to 0 &macro_param_1to1 &kp MACRO_PLACEHOLDER>;
            label = "TO_LAYER_0";
        };

        exit_AML: exit_AML {
            compatible = "zmk,behavior-macro";
            wait-ms = <0>;
            tap-ms = <0>;
            #binding-cells = <0>;
            bindings = <&tog_off MOUSE>;
            label = "exit_AML";
        };

        kp_exit_AML: kp_exit_AML {
            compatible = "zmk,behavior-macro-one-param";
            wait-ms = <0>;
            tap-ms = <0>;
            #binding-cells = <1>;
            bindings = <&macro_param_1to1 &kp MACRO_PLACEHOLDER &exit_AML>;
            label = "KP_exit_AML";
        };

        // 英数化してから ESC:
        // - macOS: LANG2 = 英数（IME オフ相当）
        // - Windows: MS IME でも LANG2 = ImeOff（半角英数）: Keyboard Japan - ImeOn / ImeOff Implementation
        // - Windows で「英字（US）キーボード」設定のとき LANG2 だけ届かないことがあるため、その補助として
        //   F22 を続けて送る。MS 系 IME の「キーとタッチのカスタマイズ」で F22 に「IME オフ」等を割り当てる。
        //   未割当の F22 は大抵無視される。macOS で F22 が邪魔なら F キーを差し替え、または LANG2 のみに戻す。

        esc_eisu: esc_eisu {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            label = "ESC_EISU";
            wait-ms = <10>;
            tap-ms = <5>;
            bindings = <&kp LANG2 &kp F22 &kp ESC>;
        };
    };

    behaviors {
        lt_to_layer_0: lt_to_layer_0 {
            compatible = "zmk,behavior-hold-tap";
            label = "LAYER_TAP_TO_0";
            bindings = <&mo>, <&to_layer_0>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
        };

        tog_off: toggle_layer_off {
            compatible = "zmk,behavior-toggle-layer";
            #binding-cells = <1>;
            display-name = "Toggle Layer Off";
            toggle-mode = "off";
        };

        mt_exit_AML_on_tap: mt_exit_AML_on_tap {
            compatible = "zmk,behavior-hold-tap";
            label = "MT_exit_AML_ON_TAP";
            bindings = <&kp>, <&kp_exit_AML>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "balanced";
            quick-tap-ms = <200>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
&kp Q      &kp W         &kp E         &kp R                           &kp T                                                    &kp Y        &kp U  &lt 4 I    &kp O    &kp P
&kp A      &kp S         &kp D         &kp F                           &kp G        &esc_eisu                    &kp MINUS      &kp H        &kp J  &kp K      &kp L    &kp SQT
&kp Z      &kp X         &kp C         &kp V                           &lt 5 B      &kp COLON                    &kp SEMICOLON  &kp N        &kp M  &kp COMMA  &kp DOT  &kp SLASH
&kp LCTRL  &kp LEFT_ALT  &kp LEFT_GUI  &mt_exit_AML_on_tap LSHIFT TAB  &lt 1 SPACE  &mt LA(LCTRL) LA(GRAVE)      &kp BACKSPACE  &lt 2 ENTER                             &kp DEL
            >;
        };

        NUM {
            bindings = <
&kp PLUS      &kp N7  &kp N8  &kp N9  &kp EQUAL                       &kp F1   &kp F2   &kp F3  &kp F4  &kp F5
&kp MINUS     &kp N4  &kp N5  &kp N6  &kp N0     &trans       &trans  &kp F6   &kp F7   &kp F8  &kp F9  &kp F10
&kp ASTERISK  &kp N1  &kp N2  &kp N3  &kp SLASH  &kp DOT      &trans  &kp F11  &kp F12  &trans  &trans  &trans
&trans        &trans  &trans  &trans  &trans     &trans       &trans  &trans                            &trans
            >;
        };

        ARROW {
            bindings = <
&kp EXCLAMATION  &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS  &kp CARET     &kp DOLLAR                                &kp LC(PAGE_UP)  &kp LS(TAB)     &kp TAB       &kp LC(PAGE_DOWN)  &trans
&kp QUESTION     &kp LEFT_BRACKET      &kp RIGHT_BRACKET      &kp ASTERISK  &kp AMPERSAND  &kp GRAVE          &trans  &kp LEFT         &kp DOWN_ARROW  &kp UP_ARROW  &kp RIGHT_ARROW    &trans
&kp PERCENT      &kp LEFT_BRACE        &kp RIGHT_BRACE        &kp HASH      &kp AT_SIGN    &kp BACKSLASH      &trans  &kp HOME         &kp PAGE_DOWN   &kp PAGE_UP   &kp END            &trans
&trans           &trans                &trans                 &trans        &trans         &trans             &trans  &trans                                                            &trans
            >;
        };

        AUTO_MOUSE {
            bindings = <
&trans  &trans  &trans  &trans  &trans                      &trans  &trans    &trans    &trans    &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans  &mkp MB1  &mkp MB3  &mkp MB2  &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans  &trans    &trans    &trans    &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans                                &trans
            >;
        };

        SCROLL {
            bindings = <
&trans  &trans  &trans  &trans  &trans                      &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans                          &trans
            >;
        };

        BLUETOOTH {
            bindings = <
&trans  &trans  &trans  &trans  &trans                           &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4
&trans  &trans  &trans  &trans  &trans  &trans      &trans       &trans        &trans        &trans        &trans        &trans
&trans  &trans  &trans  &trans  &trans  &trans      &bootloader  &trans        &trans        &trans        &trans        &bt BT_CLR
&trans  &trans  &trans  &trans  &trans  &trans      &trans       &trans                                                  &bt BT_CLR_ALL
            >;
        };
    };
};
